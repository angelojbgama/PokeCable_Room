POKECABLE_SECRET_KEY=change-me-before-production
ROOM_TIMEOUT_SECONDS=900
MAX_ROOMS=200
LOG_LEVEL=INFO
ALLOW_CROSS_GENERATION=false
ENABLED_TRADE_MODES=
POKECABLE_CLIENT_AUTO_TRADE_EVOLUTION=true
POKECABLE_CLIENT_ITEM_TRADE_EVOLUTIONS_ENABLED=false
SHOWDOWN_ENABLED=true
# Optional remote Showdown bridge URL for a future HTTP adapter.
SHOWDOWN_SERVER_URL=
# Optional: persistent JSON-lines worker command.
# If unset or unavailable, the server uses the built-in local Showdown-compatible adapter.
SHOWDOWN_PROCESS_CMD=node /srv/pokecable-showdown-worker/worker.js
